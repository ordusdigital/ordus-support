        "jsonBody": "={\"number\": \"5519997052849\", \"text\": \"📝 *Artigo Criado!*\\n\\nArquivo: \" + $json.filename + \"\\n\\nDeploy automático iniciado. Portal atualizado em ~2min.\\n🔗 https://suporte.ordussystem.com.br\"}",
        "options": {}
